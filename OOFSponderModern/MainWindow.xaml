<Window x:Class="OOFSponderModern.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OOFSponder Modern Preview" Icon="pack://application:,,,/Assets/AppIcon.ico" Height="900" Width="1280" MinHeight="760" MinWidth="1040"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid>
        <Grid Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="OOFSponder Modern" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Schedule-driven OOF preview with tabbed controls." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="15" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <StackPanel Margin="0,0,18,0" Width="360">
                        <TextBlock Text="Color template" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ThemePaletteText}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,2,0,6" />
                        <UniformGrid Columns="4">
                            <Button Command="{Binding SelectProductivityBlueCommand}" Style="{StaticResource PaletteButtonStyle}" ToolTip="Productivity Blue: balanced blue palette for quiet productivity workflows.">
                                <StackPanel>
                                    <TextBlock Text="Blue" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                                    <UniformGrid Columns="3" Height="7" Margin="0,4,0,0">
                                        <Border Background="#2563EB" CornerRadius="2,0,0,2" />
                                        <Border Background="#0F766E" />
                                        <Border Background="#DBEAFE" CornerRadius="0,2,2,0" />
                                    </UniformGrid>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SelectTrustNavyCommand}" Style="{StaticResource PaletteButtonStyle}" ToolTip="Trust Navy: navy-led palette for trust and operational clarity.">
                                <StackPanel>
                                    <TextBlock Text="Navy" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                                    <UniformGrid Columns="3" Height="7" Margin="0,4,0,0">
                                        <Border Background="#1D4ED8" CornerRadius="2,0,0,2" />
                                        <Border Background="#0369A1" />
                                        <Border Background="#DBEAFE" CornerRadius="0,2,2,0" />
                                    </UniformGrid>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SelectTealMintCommand}" Style="{StaticResource PaletteButtonStyle}" ToolTip="Teal Mint: calm retention-focused workflow palette.">
                                <StackPanel>
                                    <TextBlock Text="Teal" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                                    <UniformGrid Columns="3" Height="7" Margin="0,4,0,0">
                                        <Border Background="#0D9488" CornerRadius="2,0,0,2" />
                                        <Border Background="#059669" />
                                        <Border Background="#CCFBF1" CornerRadius="0,2,2,0" />
                                    </UniformGrid>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SelectPremiumGoldCommand}" Style="{StaticResource PaletteButtonStyle}" ToolTip="Premium Gold: navy and gold palette for a formal premium feel.">
                                <StackPanel>
                                    <TextBlock Text="Gold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                                    <UniformGrid Columns="3" Height="7" Margin="0,4,0,0">
                                        <Border Background="#1E3A8A" CornerRadius="2,0,0,2" />
                                        <Border Background="#B45309" />
                                        <Border Background="#FEF3C7" CornerRadius="0,2,2,0" />
                                    </UniformGrid>
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                    <TextBlock Text="{Binding ThemePaletteDescription}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Width="220" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <TextBlock Text="{Binding ThemeModeText}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <Button Content="{Binding ToggleThemeText}" Command="{Binding ToggleThemeCommand}" ToolTip="Switch between light and dark theme." />
                </StackPanel>
            </Grid>

            <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,18">
                <Border Style="{StaticResource StatusCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Current mode" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding CurrentOofMode}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatusCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Next window" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding NextOofWindowText}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatusCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Schedule status" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ScheduleStatus}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatusCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Sync status" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding SyncStatus}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatusCardStyle}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="Audience" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding AudienceScopeText}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TabControl x:Name="FeatureTabs" Grid.Row="2">
                <TabItem Header="Schedule">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1.25*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,18,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Work schedule" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="Set normal work hours. Off-work days bridge from the prior workday end to the next working start." Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <CheckBox Content="Link start/end time" IsChecked="{Binding IsLinkedTimeAdjustmentEnabled}" VerticalAlignment="Center" ToolTip="When enabled, changing start or end time shifts the other time by the same amount." />
                                        <TextBlock Text="{Binding LinkedTimeAdjustmentText}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding ScheduleDays}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,7" Background="{DynamicResource PanelSubtleBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="134" />
                                                        <ColumnDefinition Width="134" />
                                                        <ColumnDefinition Width="112" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DayName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                                                        <TextBox Text="{Binding StartTimeText, UpdateSourceTrigger=LostFocus}" Width="74" Margin="0,0,4,0" Padding="8,6" ToolTip="Workday start time. Type HH:mm, or use + / - to adjust by 30 minutes." />
                                                        <StackPanel Width="22" VerticalAlignment="Center">
                                                            <Button Content="+" Command="{Binding MoveStartLaterCommand}" Style="{StaticResource QuickTimeButtonStyle}" ToolTip="Start time plus 30 minutes" />
                                                            <Button Content="-" Command="{Binding MoveStartEarlierCommand}" Style="{StaticResource QuickTimeButtonStyle}" ToolTip="Start time minus 30 minutes" Margin="0,2,0,0" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,10,0">
                                                        <TextBox Text="{Binding EndTimeText, UpdateSourceTrigger=LostFocus}" Width="74" Margin="0,0,4,0" Padding="8,6" ToolTip="Workday end time. Type HH:mm, or use + / - to adjust by 30 minutes." />
                                                        <StackPanel Width="22" VerticalAlignment="Center">
                                                            <Button Content="+" Command="{Binding MoveEndLaterCommand}" Style="{StaticResource QuickTimeButtonStyle}" ToolTip="End time plus 30 minutes" />
                                                            <Button Content="-" Command="{Binding MoveEndEarlierCommand}" Style="{StaticResource QuickTimeButtonStyle}" ToolTip="End time minus 30 minutes" Margin="0,2,0,0" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <CheckBox Grid.Column="3" Content="Off work" IsChecked="{Binding IsOffWork}" VerticalAlignment="Center" ToolTip="Mark this day as non-working. OOF stays active until the next working start." />
                                                    <TextBlock Grid.Column="4" Text="{Binding VisualSummary}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Apply / preview" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Profile to apply" Style="{StaticResource LabelTextStyle}" />
                                <ComboBox ItemsSource="{Binding TemplateTargets}" SelectedItem="{Binding SelectedApplyProfile}" ToolTip="Choose which message profile will be sent to Microsoft 365 when you click Apply to M365." />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="Refresh Preview" Command="{Binding PreviewCommand}" ToolTip="Recalculate the preview payload without sending changes to Microsoft 365." />
                                    <Button Content="Apply to M365" Command="{Binding ApplyToM365Command}" Background="{DynamicResource SuccessBrush}" ToolTip="Send the selected profile and schedule to Microsoft 365 automatic replies. A confirmation prompt appears first." />
                                </StackPanel>
                                <TextBox Text="{Binding PreviewText, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" Height="520" ToolTip="Sanitized preview. Message bodies are not logged in diagnostics." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Messages">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,18,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Primary profile" Style="{StaticResource SectionTitleStyle}" />
                                <TextBox Grid.Row="1" Text="{Binding PrimaryInternalMessage, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="210" ToolTip="Internal reply for normal scheduled OOF windows." />
                                <TextBlock Grid.Row="2" Text="External" Style="{StaticResource LabelTextStyle}" />
                                <TextBox Grid.Row="3" Text="{Binding PrimaryExternalMessage, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="210" ToolTip="External reply for normal scheduled OOF windows. Audience scope controls who receives it." />
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,18,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Extended profile" Style="{StaticResource SectionTitleStyle}" />
                                <TextBox Grid.Row="1" Text="{Binding ExtendedInternalMessage, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="210" ToolTip="Internal reply for longer away periods, such as vacation or extended leave." />
                                <TextBlock Grid.Row="2" Text="External" Style="{StaticResource LabelTextStyle}" />
                                <TextBox Grid.Row="3" Text="{Binding ExtendedExternalMessage, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="210" ToolTip="External reply for longer away periods. Include backup contact details when useful." />
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Audience scope" Style="{StaticResource SectionTitleStyle}" />
                                <ComboBox ItemsSource="{Binding AudienceScopes}" SelectedItem="{Binding SelectedAudienceScope}" ToolTip="Controls external replies only. Internal users always receive the internal reply." />
                                <Border Background="{DynamicResource AccentSoftBrush}" CornerRadius="8" Padding="14" Margin="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding AudienceScopeDescription}" TextWrapping="Wrap" Foreground="{DynamicResource AccentTextBrush}" />
                                        <TextBlock Text="Message text stays in the editor. Diagnostics only report presence and character counts." TextWrapping="Wrap" Foreground="{DynamicResource AccentTextBrush}" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Message Suggestions">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,18,0">
                            <StackPanel>
                                <TextBlock Text="Suggestion controls" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Target profile" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                                <ComboBox ItemsSource="{Binding TemplateTargets}" SelectedItem="{Binding SelectedTemplateTarget}" ToolTip="Choose which profile the generated suggestion should target." />
                                <Button Content="Generate suggestion" Command="{Binding GenerateTemplateCommand}" Margin="0,8,0,0" ToolTip="Generate local OOF message suggestions from the current schedule context." />
                                <Button Content="Apply suggestion" Command="{Binding ApplyGeneratedTemplateCommand}" Background="{DynamicResource SuccessBrush}" Margin="0,8,0,0" ToolTip="Copy the generated suggestion into the selected profile editor. This does not send to Microsoft 365." />
                                <Border Background="{DynamicResource AccentSoftBrush}" CornerRadius="8" Padding="14" Margin="0,16,0,0">
                                    <TextBlock Text="{Binding TemplateStatus}" TextWrapping="Wrap" Foreground="{DynamicResource AccentTextBrush}" />
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,18,0">
                            <StackPanel>
                                <TextBlock Text="Internal suggestion" Style="{StaticResource SectionTitleStyle}" />
                                <TextBox Text="{Binding GeneratedInternalTemplate, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" Height="530" ToolTip="Generated internal reply suggestion." />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="External suggestion" Style="{StaticResource SectionTitleStyle}" />
                                <TextBox Text="{Binding GeneratedExternalTemplate, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" Height="530" ToolTip="Generated external reply suggestion." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Sync / Diagnostics">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1.6*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,18,0">
                            <StackPanel>
                                <TextBlock Text="Connection state" Style="{StaticResource SectionTitleStyle}" />
                                <Border Background="{DynamicResource PanelSubtleBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Auth state" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding AuthState}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource PanelSubtleBrush}" CornerRadius="8" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Sync state" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding SyncStatus}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Recent activity" Style="{StaticResource SectionTitleStyle}" />
                                <ItemsControl ItemsSource="{Binding RecentActivity}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>

<Window x:Class="OOFSponderModern.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OOFSponder Modern" Icon="pack://application:,,,/Assets/AppIcon.ico" Height="940" Width="1360" MinHeight="820" MinWidth="1120" WindowStartupLocation="CenterScreen" ShowInTaskbar="True"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid>
        <Grid Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="OOFSponder Modern" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Review and apply your next out-of-office interval to Microsoft 365." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="15" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Visibility="{Binding IsOnboardingVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Background="{DynamicResource AccentSoftBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="First-run guidance" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AccentTextBrush}" />
                        <TextBlock Text="Review your work schedule, choose the message profile to apply, load current Microsoft 365 settings, then use Apply to M365 after the review prompt." Foreground="{DynamicResource AccentTextBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Got it" Command="{Binding DismissOnboardingCommand}" Margin="18,0,0,0" VerticalAlignment="Center" ToolTip="Hide this first-run guidance." />
                </Grid>
            </Border>

            <Border Grid.Row="2" Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" Background="{DynamicResource AccentSoftBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Update available" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource AccentTextBrush}" />
                        <TextBlock Text="{Binding UpdateNotificationText}" Foreground="{DynamicResource AccentTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding UpdateReleaseNotes}" Foreground="{DynamicResource AccentTextBrush}" TextWrapping="Wrap" MaxHeight="92" Margin="0,6,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="18,0,0,0" VerticalAlignment="Center">
                        <Button Content="View release" Command="{Binding OpenReleasePageCommand}" ToolTip="Open the verified HTTPS GitHub Release page in your browser." />
                        <Button Content="Skip this version" Command="{Binding SkipReleaseCommand}" Margin="8,0,0,0" ToolTip="Hide this version. A later release will still be shown." />
                    </StackPanel>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="3" Columns="5" Margin="0,0,0,18">
                <Border Style="{StaticResource StatusCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Current mode" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding CurrentOofMode}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatusCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Next window" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding NextOofWindowText}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatusCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Schedule status" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding ScheduleStatus}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatusCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Sync status" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding SyncStatus}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatusCardStyle}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="Audience" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Text="{Binding AudienceScopeText}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TabControl x:Name="FeatureTabs" Grid.Row="4">
                <TabItem Header="Schedule">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1.25*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,18,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Work schedule" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="Schedule source" Style="{StaticResource LabelTextStyle}" />
                                    <ComboBox ItemsSource="{Binding ScheduleSourceDisplayNames}" SelectedItem="{Binding SelectedScheduleSourceDisplayName}" ToolTip="Choose normal weekly calculation or an explicit long-leave interval." />
                                    <TextBlock Text="Set normal work hours, or choose Long leave to enter one explicit interval. Applying to Microsoft 365 is always manual." Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <CheckBox Content="Link start/end time" IsChecked="{Binding IsLinkedTimeAdjustmentEnabled}" VerticalAlignment="Center" ToolTip="When enabled, changing start or end time shifts the other time by the same amount." />
                                        <TextBlock Text="{Binding LinkedTimeAdjustmentText}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Row="1" Visibility="{Binding IsLongLeaveMode, Converter={StaticResource BooleanToVisibilityConverter}}" Background="{DynamicResource AccentSoftBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="110" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.ColumnSpan="5" Text="Explicit long-leave interval" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AccentTextBrush}" Margin="0,0,0,10" />
                                        <StackPanel Grid.Row="1">
                                            <TextBlock Text="Start date" Style="{StaticResource LabelTextStyle}" />
                                            <DatePicker SelectedDate="{Binding LongLeaveStartDate, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,8,12" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <TextBlock Text="Start time" Style="{StaticResource LabelTextStyle}" />
                                            <TextBox Text="{Binding LongLeaveStartTimeText, UpdateSourceTrigger=LostFocus}" ToolTip="Local time, for example 09:00." />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="3">
                                            <TextBlock Text="Return date" Style="{StaticResource LabelTextStyle}" />
                                            <DatePicker SelectedDate="{Binding LongLeaveEndDate, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,8,12" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="4">
                                            <TextBlock Text="Return time" Style="{StaticResource LabelTextStyle}" />
                                            <TextBox Text="{Binding LongLeaveEndTimeText, UpdateSourceTrigger=LostFocus}" ToolTip="Local time, for example 09:00." />
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                                            <TextBlock Text="Local label (optional)" Style="{StaticResource LabelTextStyle}" />
                                            <TextBox Text="{Binding LongLeaveLabel, UpdateSourceTrigger=PropertyChanged}" ToolTip="Shown locally in preview and review; not sent as a separate Graph field." />
                                        </StackPanel>
                                        <TextBlock Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="2" Text="{Binding LongLeaveStatus}" Foreground="{DynamicResource AccentTextBrush}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <ItemsControl Grid.Row="2" ItemsSource="{Binding ScheduleDays}" IsEnabled="{Binding IsWeeklyScheduleMode}" ToolTip="Weekly hours are preserved while Long leave mode is active.">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,7" Background="{DynamicResource PanelSubtleBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="134" />
                                                        <ColumnDefinition Width="134" />
                                                        <ColumnDefinition Width="112" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DayName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                                                        <TextBox Text="{Binding StartTimeText, UpdateSourceTrigger=LostFocus}" Width="74" Margin="0,0,4,0" Padding="8,6" ToolTip="Workday start time. Type HH:mm, or use + / - to adjust by 30 minutes." />
                                                        <StackPanel Width="22" VerticalAlignment="Center">
                                                            <Button Content="+" Command="{Binding MoveStartLaterCommand}" Style="{StaticResource QuickTimeButtonStyle}" ToolTip="Start time plus 30 minutes" />
                                                            <Button Content="-" Command="{Binding MoveStartEarlierCommand}" Style="{StaticResource QuickTimeButtonStyle}" ToolTip="Start time minus 30 minutes" Margin="0,2,0,0" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,10,0">
                                                        <TextBox Text="{Binding EndTimeText, UpdateSourceTrigger=LostFocus}" Width="74" Margin="0,0,4,0" Padding="8,6" ToolTip="Workday end time. Type HH:mm, or use + / - to adjust by 30 minutes." />
                                                        <StackPanel Width="22" VerticalAlignment="Center">
                                                            <Button Content="+" Command="{Binding MoveEndLaterCommand}" Style="{StaticResource QuickTimeButtonStyle}" ToolTip="End time plus 30 minutes" />
                                                            <Button Content="-" Command="{Binding MoveEndEarlierCommand}" Style="{StaticResource QuickTimeButtonStyle}" ToolTip="End time minus 30 minutes" Margin="0,2,0,0" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <CheckBox Grid.Column="3" Content="Off work" IsChecked="{Binding IsOffWork}" VerticalAlignment="Center" ToolTip="Mark this day as non-working. OOF stays active until the next working start." />
                                                    <TextBlock Grid.Column="4" Text="{Binding VisualSummary}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Apply / preview" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Profile to apply" Style="{StaticResource LabelTextStyle}" />
                                <ComboBox ItemsSource="{Binding TemplateTargets}" SelectedItem="{Binding SelectedApplyProfile}" ToolTip="Choose which message profile will be sent to Microsoft 365 when you click Apply to M365." />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="Refresh Preview" Command="{Binding PreviewCommand}" ToolTip="Recalculate the preview payload without sending changes to Microsoft 365." />
                                    <Button Content="Apply to M365" Command="{Binding ApplyToM365Command}" Background="{DynamicResource SuccessBrush}" ToolTip="Send the selected profile and schedule to Microsoft 365 automatic replies. A confirmation prompt appears first." />
                                </StackPanel>
                                <Border Visibility="{Binding IsApplyResultVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Background="{DynamicResource AccentSoftBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ApplyResultText}" Foreground="{DynamicResource AccentTextBrush}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="Clear" Command="{Binding ClearApplyResultCommand}" Margin="12,0,0,0" Padding="10,6" ToolTip="Clear the latest apply result banner." />
                                    </Grid>
                                </Border>
                                <TextBox Text="{Binding PreviewText, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" Height="520" ToolTip="Sanitized preview. Message bodies are not logged in diagnostics." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Messages">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,18,18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Primary profile" Style="{StaticResource SectionTitleStyle}" />
                                <TextBox Grid.Row="1" Text="{Binding PrimaryInternalMessage, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="150" ToolTip="Internal reply for normal scheduled OOF windows." />
                                <TextBlock Grid.Row="2" Text="External" Style="{StaticResource LabelTextStyle}" />
                                <TextBox Grid.Row="3" Text="{Binding PrimaryExternalMessage, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="150" ToolTip="External reply for normal scheduled OOF windows. Audience scope controls who receives it." />
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,18,18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Extended profile" Style="{StaticResource SectionTitleStyle}" />
                                <TextBox Grid.Row="1" Text="{Binding ExtendedInternalMessage, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="150" ToolTip="Internal reply for longer away periods, such as vacation or extended leave." />
                                <TextBlock Grid.Row="2" Text="External" Style="{StaticResource LabelTextStyle}" />
                                <TextBox Grid.Row="3" Text="{Binding ExtendedExternalMessage, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="150" ToolTip="External reply for longer away periods. Include backup contact details when useful." />
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Audience scope" Style="{StaticResource SectionTitleStyle}" />
                                <ComboBox ItemsSource="{Binding AudienceScopeDisplayNames}" SelectedItem="{Binding SelectedAudienceScopeDisplayName}" ToolTip="Controls external replies only. Internal users always receive the internal reply." />
                                <Border Background="{DynamicResource AccentSoftBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,18">
                                    <StackPanel>
                                        <TextBlock Text="{Binding AudienceScopeDescription}" TextWrapping="Wrap" Foreground="{DynamicResource AccentTextBrush}" />
                                        <TextBlock Text="Message text stays in the editor. Diagnostics only report presence and character counts." TextWrapping="Wrap" Foreground="{DynamicResource AccentTextBrush}" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Suggestions" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Target profile" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                                <ComboBox ItemsSource="{Binding TemplateTargets}" SelectedItem="{Binding SelectedTemplateTarget}" ToolTip="Choose which profile the generated suggestion should target." />
                                <Button Content="Generate suggestion" Command="{Binding GenerateTemplateCommand}" Margin="0,4,0,0" ToolTip="Generate local OOF message suggestions from the current schedule context." />
                                <Button Content="Apply suggestion" Command="{Binding ApplyGeneratedTemplateCommand}" Background="{DynamicResource SuccessBrush}" Margin="0,8,0,0" ToolTip="Copy the generated suggestion into the selected profile editor. This does not send to Microsoft 365." />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.ColumnSpan="3" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="300" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Text="Internal suggestion" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBox Text="{Binding GeneratedInternalTemplate, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" Height="160" ToolTip="Generated internal reply suggestion." />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                    <TextBlock Text="External suggestion" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBox Text="{Binding GeneratedExternalTemplate, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" Height="160" ToolTip="Generated external reply suggestion." />
                                </StackPanel>
                                <Border Grid.Column="2" Background="{DynamicResource AccentSoftBrush}" CornerRadius="8" Padding="14">
                                    <TextBlock Text="{Binding TemplateStatus}" TextWrapping="Wrap" Foreground="{DynamicResource AccentTextBrush}" />
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource CardStyle}" Margin="0,18,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Text="Saved message templates" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="Template" Style="{StaticResource LabelTextStyle}" />
                                    <ComboBox ItemsSource="{Binding MessageTemplates}" SelectedItem="{Binding SelectedMessageTemplate}" DisplayMemberPath="Name" ToolTip="Select a saved message template." />
                                    <TextBlock Text="Template name" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox Text="{Binding TemplateName, UpdateSourceTrigger=PropertyChanged}" ToolTip="A unique name for this saved template." />
                                    <TextBlock Text="{}{UserName} display name" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox Text="{Binding TemplateDisplayName, UpdateSourceTrigger=LostFocus}" ToolTip="Used locally to resolve the UserName template variable." />
                                    <TextBlock Text="Available variables" Style="{StaticResource LabelTextStyle}" />
                                    <TextBlock Text="{Binding SupportedTemplateVariables}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,12" />
                                    <WrapPanel>
                                        <Button Content="New" Command="{Binding NewMessageTemplateCommand}" ToolTip="Start a new message template." />
                                        <Button Content="Save" Command="{Binding SaveMessageTemplateCommand}" Margin="6,0,0,0" ToolTip="Save this named template locally." />
                                        <Button Content="Delete" Command="{Binding DeleteMessageTemplateCommand}" Margin="6,0,0,0" ToolTip="Delete the selected template after confirmation." />
                                    </WrapPanel>
                                    <Button Content="Resolve preview" Command="{Binding PreviewMessageTemplateCommand}" Margin="0,8,0,0" ToolTip="Resolve variables into the suggestion preview. This does not contact Microsoft 365." />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                    <TextBlock Text="Internal template" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBox Text="{Binding TemplateInternalText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="220" ToolTip="Internal message template. Supported variables are resolved only in preview and when copied to a profile." />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="External template" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBox Text="{Binding TemplateExternalText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="220" ToolTip="External message template. Audience scope still controls who receives it." />
                                </StackPanel>
                                <Border Grid.Row="1" Grid.ColumnSpan="3" Background="{DynamicResource PanelSubtleBrush}" CornerRadius="8" Padding="12" Margin="0,14,0,0">
                                    <TextBlock Text="Templates are saved locally. Resolve preview replaces supported variables using the current OOF window; Apply suggestion then copies the resolved text to the selected Primary or Extended profile." Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Configuration">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,18,18">
                            <StackPanel>
                                <TextBlock Text="Appearance" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="App theme only" Style="{StaticResource LabelTextStyle}" />
                                <TextBlock Text="{Binding ThemePaletteText}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,2,0,10" />
                                <UniformGrid Columns="4" Margin="0,0,0,18">
                                    <Button Command="{Binding SelectProductivityBlueCommand}" Style="{StaticResource PaletteButtonStyle}" ToolTip="Productivity Blue: balanced blue palette for quiet productivity workflows.">
                                        <StackPanel>
                                            <TextBlock Text="Blue" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                                            <UniformGrid Columns="3" Height="7" Margin="0,4,0,0">
                                                <Border Background="#2563EB" CornerRadius="2,0,0,2" />
                                                <Border Background="#0F766E" />
                                                <Border Background="#DBEAFE" CornerRadius="0,2,2,0" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding SelectTrustNavyCommand}" Style="{StaticResource PaletteButtonStyle}" ToolTip="Trust Navy: navy-led palette for trust and operational clarity.">
                                        <StackPanel>
                                            <TextBlock Text="Navy" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                                            <UniformGrid Columns="3" Height="7" Margin="0,4,0,0">
                                                <Border Background="#1D4ED8" CornerRadius="2,0,0,2" />
                                                <Border Background="#0369A1" />
                                                <Border Background="#DBEAFE" CornerRadius="0,2,2,0" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding SelectTealMintCommand}" Style="{StaticResource PaletteButtonStyle}" ToolTip="Teal Mint: calm retention-focused workflow palette.">
                                        <StackPanel>
                                            <TextBlock Text="Teal" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                                            <UniformGrid Columns="3" Height="7" Margin="0,4,0,0">
                                                <Border Background="#0D9488" CornerRadius="2,0,0,2" />
                                                <Border Background="#059669" />
                                                <Border Background="#CCFBF1" CornerRadius="0,2,2,0" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding SelectPremiumGoldCommand}" Style="{StaticResource PaletteButtonStyle}" ToolTip="Premium Gold: navy and gold palette for a formal premium feel.">
                                        <StackPanel>
                                            <TextBlock Text="Gold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                                            <UniformGrid Columns="3" Height="7" Margin="0,4,0,0">
                                                <Border Background="#1E3A8A" CornerRadius="2,0,0,2" />
                                                <Border Background="#B45309" />
                                                <Border Background="#FEF3C7" CornerRadius="0,2,2,0" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Button>
                                </UniformGrid>
                                <TextBlock Text="{Binding ThemePaletteDescription}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,18" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ThemeModeText}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <Button Content="{Binding ToggleThemeText}" Command="{Binding ToggleThemeCommand}" ToolTip="Switch between light and dark theme." />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Schedule Behavior" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Time editing" Style="{StaticResource LabelTextStyle}" />
                                <CheckBox Content="Link start/end time" IsChecked="{Binding IsLinkedTimeAdjustmentEnabled}" Margin="0,8,0,10" ToolTip="When enabled, changing start or end time shifts the other time by the same amount." />
                                <TextBlock Text="{Binding LinkedTimeAdjustmentText}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,18,0">
                            <StackPanel>
                                <TextBlock Text="Microsoft 365 Safety" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Apply behavior" Style="{StaticResource LabelTextStyle}" />
                                <TextBlock Text="Apply to M365 shows a review prompt before Microsoft Graph is updated. Message bodies are omitted from diagnostics and activity logs." Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,8,0,14" />
                                <TextBlock Text="Current apply profile" Style="{StaticResource LabelTextStyle}" />
                                <TextBlock Text="{Binding ApplyProfileText}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Local App Settings" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Saved on this PC" Style="{StaticResource LabelTextStyle}" />
                                <TextBlock Text="OOFSponderModern saves schedule, messages, theme, selected profiles, checklist state, and window size under your AppData profile." Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,8,0,14" />
                                <TextBlock Text="Window placement" Style="{StaticResource LabelTextStyle}" />
                                <TextBlock Text="The app opens centered and restores only the previous window size." Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                <TextBlock Text="Windows startup" Style="{StaticResource LabelTextStyle}" Margin="0,18,0,0" />
                                <CheckBox Content="Start OOFSponder Modern when I sign in to Windows" IsChecked="{Binding StartWithWindows}" Margin="0,8,0,0" ToolTip="Launch the app automatically after you sign in to your Windows account." />
                                <TextBlock Text="Updates" Style="{StaticResource LabelTextStyle}" Margin="0,18,0,0" />
                                <TextBlock Text="{Binding CurrentVersionText}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding UpdateStatusText}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,10" />
                                <Button Content="Check for updates" Command="{Binding CheckForUpdatesCommand}" HorizontalAlignment="Left" ToolTip="Check the latest public GitHub Release. No update is downloaded automatically." />
                            </StackPanel>
                        </Border>
                    </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Sync / Diagnostics">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1.6*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,18,0">
                            <StackPanel>
                                <TextBlock Text="Connection state" Style="{StaticResource SectionTitleStyle}" />
                                <Border Background="{DynamicResource PanelSubtleBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Auth state" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding AuthState}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource PanelSubtleBrush}" CornerRadius="8" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Sync state" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding SyncStatus}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Button Content="Load current M365 settings" Command="{Binding LoadCurrentM365SettingsCommand}" Margin="0,14,0,12" ToolTip="Sign in and read current Microsoft 365 automatic reply settings without changing them." />
                                <Border Background="{DynamicResource PanelSubtleBrush}" CornerRadius="8" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Current automatic replies" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding CurrentM365SettingsText}" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Recent activity" Style="{StaticResource SectionTitleStyle}" />
                                <ItemsControl ItemsSource="{Binding RecentActivity}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
